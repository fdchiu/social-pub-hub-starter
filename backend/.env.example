# Backend datastore selection
# sql (default) or mongo
DB_BACKEND=sql

# SQL backend
# SQLite default for local dev; set Postgres URL in prod
DATABASE_URL=sqlite:///./social_pub_hub.db

# Mongo backend
# Used only when DB_BACKEND=mongo
MONGODB_URI=mongodb://127.0.0.1:27017/social_pub_hub
MONGODB_DB=social_pub_hub

# Optional LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.3-codex
